# Copy this file to .env and fill in real values before running

# --- Database ---
# Option A: individual fields (used for local/Docker setup, shown below)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supermarket_pos
DB_USER=postgres
DB_PASSWORD=your_db_password

# Option B: a single connection string (used by Neon/Render/Supabase/Railway).
# If DATABASE_URL is set, it takes priority over the individual fields above.
# Example: DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# --- Server ---
PORT=4000

# --- Payment Gateway integration (placeholders) ---
# In production, plug real KPay / WavePay merchant credentials here.
KPAY_MERCHANT_ID=
WAVEPAY_MERCHANT_ID=
